---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" bannerTitle="Contact" bannerImg="/images/belmont-orthodontics-contact.jpg">
    <main class="container mx-auto mb-auto py-10">
        <div class="flex flex-col md:flex-row mx-auto">
            <div class="flex-1 m-2 lg:m-10">
                <div class="px-6">
                    <h3 class="mb-4">Practice</h3>
                    <p>Click on the links below for the contact details of your local practice.</p>
                    <h4>Belfast practice</h4>
                    <div class="flex items-top my-4 text-gray-700">
                        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <a href="tel:028 9065 6666" class="px-2 text-teal-600">028 9065 6666</a>
                    </div>
                    <h4>Downpatrick practice</h4>
                    <div class="flex items-top my-4 text-gray-700">
                        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <a href="tel:028 4461 2217" class="px-2 text-teal-600">028 4461 2217</a>
                    </div>
                    <h4>Newtownards practice</h4>
                    <div class="flex items-top my-4 text-gray-700">
                        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <a href="tel:028 9131 1784" class="px-2 text-teal-600">028 9131 1784</a>
                    </div>
                    <h3 class="mb-4">Social media</h3>

                    <a href="https://www.facebook.com/Belmont-Orthodontics-1984362005138944/" class="mr-4">
                        <i class="fab fa-facebook-square bg-white text-blue-600 text-2xl mr-2"></i>Facebook
                    </a>
                    <a href="https://www.instagram.com/belmontorthodontics/">
                        <i class="fab fa-instagram-square bg-white text-pink-600 text-2xl mr-2"></i>Instagram
                    </a>
                </div>
            </div>

            <div class="flex-1 max-w-xl m-2 lg:m-10">
                <h3 class="mb-4">Email</h3>
                <form name="contact" method="POST" data-netlify="true">
                    <input type="hidden" name="_token" value="Eo5Ej4OnzfnhSpVA8h01gBjXYvWrBrS201vPHeXl" />
                    <input
                        class="w-full block border border-gray-400 focus:outline-none focus:border-indigo-500 text-base px-4 py-2 mb-4"
                        placeholder="Full name"
                        type="text"
                        x-model="formData.name"
                        required
                    />
                    <input
                        class="w-full block border border-gray-400 focus:outline-none focus:border-indigo-500 text-base px-4 py-2 mb-4"
                        placeholder="Email address"
                        type="email"
                        x-model="formData.email"
                        required
                    />
                    <input
                        class="w-full block border border-gray-400 focus:outline-none focus:border-indigo-500 text-base px-4 py-2 mb-4"
                        placeholder="Phone (optional)"
                        type="phone"
                        x-model="formData.phone"
                        required
                    />
                    <textarea
                        class="w-full block rounded border border-gray-400 focus:outline-none h-32 focus:border-indigo-500 text-base px-4 py-2 mb-4 resize-none"
                        placeholder="Message"
                        x-model="formData.message"
                        required></textarea>
                    <button
                        class="rounded-md bg-teal-600 px-3 py-2 text-sm font-semibold text-white hover:bg-teal-400 focus-visible:outline-2 focus-visible:outline-offset-2"
                        :disabled="formLoading"
                        x-text="buttonText">Send</button
                    >
                    <p class="text-teal-500" x-text="formMessage"></p>
                </form>
            </div>
        </div>
    </main>
</Layout>
